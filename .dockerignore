# Git
.git
.gitignore

# Documentation (не нужна в образе)
README.md
docs/
*.md
!config.json

# Environment files (секреты не должны попадать в образ)
.env
.env.local
.env.production

# Logs
*.log
logs/

# Runtime data
pids
*.pid
*.seed

# Temporary files
tmp/
temp/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Backup files
*.backup
*.bak
*.sql

# Docker compose files (не нужны внутри образа)
docker-compose*.yml

# Init scripts (используется только для ручной настройки)
init-mysql.sql
