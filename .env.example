# ===========================================
# MARZBAN VPN - КОНФИГУРАЦИЯ
# ===========================================
# Скопируйте этот файл в .env и настройте значения
# cp .env.example .env

# ===========================================
# АДМИН ПАНЕЛЬ
# ===========================================
SUDO_USERNAME=admin
SUDO_PASSWORD=change_me_strong_password

# ===========================================
# БАЗА ДАННЫХ
# ===========================================
# docker-compose.marzban.yml НЕ поднимает свой контейнер БД.
#
# РЕКОМЕНДУЕТСЯ — SQLite (для одной ноды): НЕ задавай SQLALCHEMY_DATABASE_URL.
#   Файл БД ляжет в том marzban_data: /var/lib/marzban/db.sqlite3
#   Бэкап = копия одного файла, отдельный контейнер не нужен, минимум RAM.
#
# Опционально — внешняя БД (ТОЛЬКО MySQL/MariaDB; PostgreSQL не поддерживается,
#   драйвера в requirements нет). Раскомментируй и укажи хост, доступный из dokploy-network;
#   заранее создай базу marzban-db и пользователя с правами:
# SQLALCHEMY_DATABASE_URL=mysql+pymysql://marzban:your_db_password@<db-host>:3306/marzban-db

# ===========================================
# СЕТЕВЫЕ НАСТРОЙКИ
# ===========================================
UVICORN_HOST=0.0.0.0
# ВАЖНО: Порт должен совпадать с docker-compose.marzban.yml (8003)
UVICORN_PORT=8003
DOMAIN=vpn.yourdomain.com

# ===========================================
# БЕЗОПАСНОСТЬ
# ===========================================
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
DOCS=false
DEBUG=false

# ===========================================
# SSL / ВНЕШНЯЯ ДОСТУПНОСТЬ (важный нюанс Marzban v0.8.4!)
# ===========================================
# БЕЗ внутреннего SSL Marzban биндится ТОЛЬКО на 127.0.0.1 (отказывается отдавать
# голый HTTP на 0.0.0.0) → недоступен извне, в т.ч. для Traefik в отдельном контейнере.
#
# РЕКОМЕНДУЕТСЯ для Dokploy/контейнерного Traefik — оставить внутренний self-signed SSL:
DISABLE_INTERNAL_SSL=false
#   → Marzban на 0.0.0.0:${UVICORN_PORT} по HTTPS (self-signed).
#   → Панель напрямую: https://<server-ip>:8003 (примешь предупреждение о сертификате).
#   → Через Traefik: включи в Dokploy HTTPS для внутреннего порта приложения.
#
# Для ВАЛИДНОГО сертификата (нужно для subscription-ссылок в клиентах) — Let's Encrypt:
# USE_LETSENCRYPT_CERTS=true
# LETSENCRYPT_CERT_PATH=/etc/letsencrypt/live/vpn.yourdomain.com/fullchain.pem
# LETSENCRYPT_KEY_PATH=/etc/letsencrypt/live/vpn.yourdomain.com/privkey.pem
#
# DISABLE_INTERNAL_SSL=true имеет смысл ТОЛЬКО если reverse-proxy в том же network
# namespace (host networking) и сам терминирует TLS — для Dokploy это НЕ так.

# ===========================================
# XRAY КОНФИГУРАЦИЯ
# ===========================================
XRAY_JSON=/var/lib/marzban/xray_config.json
XRAY_EXECUTABLE_PATH=/usr/local/bin/xray
XRAY_ASSETS_PATH=/usr/local/share/xray

# ===========================================
# VLESS REALITY КЛЮЧИ (ВАЖНО!)
# ===========================================
# Если оставить пустыми — entrypoint при первом старте САМ сгенерит пару,
# сохранит в /var/lib/marzban/reality_keys.env и выведет в логи (docker logs marzban).
# Скопируй оттуда сюда — чтобы ключи пережили пересоздание тома:
#
# REALITY_PRIVATE_KEY=your_private_key_here
# REALITY_PUBLIC_KEY=your_public_key_here
#
# ВАЖНО: НЕ используй кнопку генерации ключей в панели Marzban v0.8.4 — она ждёт старый
# формат вывода x25519 (Private key/Public key), а Xray v26 выдаёт новый (PrivateKey/Password).
# Бери ключи только из логов контейнера или из .env.
#
# SNI/dest ЗАВИСЯТ ОТ РОЛИ НОДЫ (IP<->SNI mismatch — DPI флагует Yandex-SNI на не-РФ IP):
#  - EXIT за границей (наш случай): глобальный сервис, чьи IP правдоподобны где угодно.
#      REALITY_DEST=www.microsoft.com:443
#      REALITY_SERVER_NAMES=www.microsoft.com
#    (допустимо github.com, www.twitch.tv; НЕ apple.com — собственный ASN; НЕ ya.ru за границей!)
#  - BRIDGE в РФ: ya.ru уместен.
#      REALITY_DEST=ya.ru:443
#      REALITY_SERVER_NAMES=ya.ru,www.ya.ru

# ===========================================
# CLOUDFLARE TUNNEL (для cf.sethub.org:443 через cloudflared)
# ===========================================
# Решает проблему «оператор режет CF на нестандартных портах» (МТС блочит 8443).
# Cloudflared делает ИСХОДЯЩЕЕ соединение к CF, не нужно открывать никакие порты.
# Клиенты ходят на стандартный 443/tcp через cf.sethub.org.
#
# Где взять токен: CF Zero Trust dashboard → Networks → Tunnels → Create a tunnel →
# тип Cloudflared → имя marzban → копируй token из шага Install connector.
# Полная инструкция: docs/CLOUDFLARE_TUNNEL.md
#
# Запускается отдельным compose'ом: docker-compose.cloudflared.yml
CLOUDFLARE_TUNNEL_TOKEN=

# ===========================================
# WARP ИНТЕГРАЦИЯ (по умолчанию ОТКЛЮЧЕНА)
# ===========================================
# В дефолтном config.json WARP-outbound и роутинг УБРАНЫ — весь трафик идёт напрямую
# с exit-IP. Если нужен WARP (напр. OpenAI блокирует datacenter-IP): задеплой
# docker-compose.warp.yml, верни warp-outbound + routing в config.json и выставь WARP_ENABLED=true.
WARP_ENABLED=false
WARP_HOST=warp-proxy
WARP_PORT=1080

# ===========================================
# TELEGRAM УВЕДОМЛЕНИЯ
# ===========================================
# Создайте бота через @BotFather и получите токен
TELEGRAM_API_TOKEN=your_bot_token_here
# Узнайте свой ID через @userinfobot
TELEGRAM_ADMIN_ID=your_telegram_id_here

# ===========================================
# УВЕДОМЛЕНИЯ О ЛИМИТАХ
# ===========================================
# Процент трафика для предупреждения
NOTIFY_REACHED_USAGE_PERCENT=80
# За сколько дней до окончания уведомлять
NOTIFY_DAYS_LEFT=3

# ===========================================
# АВТОУДАЛЕНИЕ ПОЛЬЗОВАТЕЛЕЙ
# ===========================================
# -1 = отключено, число = дней после истечения
USERS_AUTODELETE_DAYS=-1
USER_AUTODELETE_INCLUDE_LIMITED_ACCOUNTS=false

# ===========================================
# URL ДЛЯ ПОДПИСОК
# ===========================================
XRAY_SUBSCRIPTION_URL_PREFIX=https://vpn.yourdomain.com

# ===========================================
# WEBHOOK УВЕДОМЛЕНИЯ (опционально)
# ===========================================
# WEBHOOK_ADDRESS=https://your-webhook-url.com/webhook
# WEBHOOK_SECRET=your_webhook_secret

# ===========================================
# ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ
# ===========================================
NUMBER_OF_RECURRENT_NOTIFICATIONS=3
RECURRENT_NOTIFICATIONS_TIMEOUT=180

# Кастомные JSON конфигурации для клиентов
USE_CUSTOM_JSON_DEFAULT=false
USE_CUSTOM_JSON_FOR_V2RAYNG=false
USE_CUSTOM_JSON_FOR_STREISAND=false
USE_CUSTOM_JSON_FOR_V2RAYN=false

# ===========================================
# ТАЙМАУТЫ И ЛИМИТЫ
# ===========================================
# Таймаут ожидания БД (секунды × 2 = макс. время)
DB_WAIT_RETRIES=30
# Срок действия самоподписанного сертификата (дни)
SSL_CERT_DAYS=365
