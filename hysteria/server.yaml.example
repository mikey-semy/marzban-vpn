# Hysteria2 server config — скопируй в hysteria/server.yaml и заполни значения.
# hysteria/server.yaml в .gitignore (содержит токен и пароли).

listen: :443        # UDP. Должен совпадать с портом в docker-compose.hysteria.yml

# === TLS: вариант A (рекомендуется) — Let's Encrypt через Cloudflare DNS-01 ===
# Работает, когда зона equiply.ru переведена на Cloudflare. Открытые 80/443/tcp НЕ нужны.
acme:
  domains:
    - hy.equiply.ru
  email: toshkin.mikhail@gmail.com
  ca: letsencrypt
  dir: /acme
  type: dns
  dns:
    name: cloudflare
    config:
      # CF API Token со scope: Zone.DNS:Edit для equiply.ru
      cloudflare_api_token: ВСТАВЬ_CF_API_TOKEN

# === TLS: вариант B (быстрый старт без CF) — самоподписанный сертификат ===
# Закомментируй блок acme выше, раскомментируй tls ниже, сгенерь cert
# (см. docs/HYSTERIA2.md), смонтируй cert.crt/cert.key в compose,
# и на клиенте включи insecure (Hiddify: "Allow insecure" / tls insecure).
# tls:
#   cert: /etc/hysteria/cert.crt
#   key: /etc/hysteria/cert.key

# Обфускация Salamander — прячет QUIC-хендшейк (важно против ТСПУ на CIS-направлении)
obfs:
  type: salamander
  salamander:
    password: ВСТАВЬ_OBFS_ПАРОЛЬ

# Аутентификация клиента
auth:
  type: password
  password: ВСТАВЬ_AUTH_ПАРОЛЬ

# Маскировка: при заходе обычным браузером на порт отдаётся реальный сайт (анти-зондирование)
masquerade:
  type: proxy
  proxy:
    url: https://www.microsoft.com/
    rewriteHost: true

# Полоса для congestion control (brutal). Поставь близко к реальной скорости канала клиента.
# На зажатом мобильном ТСПУ занижение тут может, наоборот, помочь стабильности — тюнить по факту.
bandwidth:
  up: 100 mbps
  down: 100 mbps

# (опц.) Порт-хоппинг для живучести: listen: :20000-50000 + iptables NAT на :443.
# Включим позже, если одиночный порт начнут резать.
